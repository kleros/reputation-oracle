{
	"name": "kleros-reputation-bot",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "node --env-file=.env --import tsx src/index.ts",
		"start:dry-run": "node --env-file=.env --import tsx src/index.ts --dry-run",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"dependencies": {
		"graphql-request": "^7.4.0",
		"viem": "^2.47.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^22.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.2"
	}
}

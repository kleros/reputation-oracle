BOT_PRIVATE_KEY=0x...

# TX_RECEIPT_TIMEOUT_MS: Receipt wait timeout in ms. Default: 120000 (L1). L2 deployments: use 30000.
# TX_RECEIPT_TIMEOUT_MS=120000

# MIN_BALANCE_WEI: Minimum wallet balance in wei before aborting. Default: 5000000000000000 (0.005 ETH).
# MIN_BALANCE_WEI=5000000000000000

# PINATA_JWT: Pinata API JWT for IPFS evidence upload. When absent, Scenario 1/2 actions are skipped.
# Requires pinJSONToIPFS scope. For integration tests, also requires unpin scope.
# PINATA_JWT=

# PINATA_TIMEOUT_MS: Pinata upload timeout in ms. Default: 30000.
# PINATA_TIMEOUT_MS=30000

# ── Phase 8: Observability (Betterstack) ────────────────────────────────────
# All three are optional. Leave commented out to skip log forwarding + heartbeat.
# Full setup procedure: deploy/RUNBOOK.md §9 Betterstack Setup.

# BETTERSTACK_SOURCE_TOKEN: Betterstack Telemetry source token. When set (and not
# --dry-run), stderr logs are forwarded to Betterstack via the @logtail/pino
# transport. Create via Betterstack → Sources → New source (kind: HTTP).
# BETTERSTACK_SOURCE_TOKEN=

# BETTERSTACK_HEARTBEAT_URL: Betterstack Uptime heartbeat URL (token embedded in
# path). When set (and not --dry-run), the bot pings this URL after every run —
# base URL on success, `${url}/fail` on systemic failure. Create via Betterstack
# → Uptime → Heartbeats → New monitor (5-min cadence, 600s grace recommended).
# BETTERSTACK_HEARTBEAT_URL=

# HEARTBEAT_TIMEOUT_MS: AbortSignal.timeout bound on the heartbeat fetch.
# Default: 10000.
# HEARTBEAT_TIMEOUT_MS=10000
